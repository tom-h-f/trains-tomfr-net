{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "trains-ui",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    { "binding": "TRAINS_HUB", "service": "trains-hub" }
  ],
  "kv_namespaces": [
    {
      "binding": "TRAINS_KV",
      "id": "72da270ed9c84b52aaa38417731b5e08"
    }
  ],
  "vars": {
    "NEXT_PUBLIC_API_WS_URL": "wss://trains-hub.canthus.workers.dev/ws"
  },
  "routes": [
    { "pattern": "trains.tomfr.net", "custom_domain": true }
  ]
}
