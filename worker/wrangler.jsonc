{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "trains-hub",
  "main": "index.ts",
  "compatibility_date": "2026-05-01",
  "durable_objects": {
    "bindings": [{ "name": "TRAIN_HUB", "class_name": "TrainHub" }]
  },
  "kv_namespaces": [
    {
      "binding": "TRAINS_KV",
      "id": "d040854d0cf34c4ba60a5e55e09f58dc"
    }
  ],
  "triggers": {
    "crons": ["0 * * * *"]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["TrainHub"] }]
}
