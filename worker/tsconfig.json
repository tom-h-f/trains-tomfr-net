{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [],
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": ["./**/*.ts", "./worker-configuration.d.ts"],
  "exclude": ["node_modules"]
}
